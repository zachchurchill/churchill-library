<div data-librarian-chat-target="backdrop" data-action="click->librarian-chat#close" class="fixed inset-0 z-20 hidden bg-slate-900/30"></div>
<aside
  id="librarian-chat-panel"
  data-librarian-chat-target="panel"
  class="fixed inset-y-0 right-0 z-30 hidden w-full max-w-md border-l border-slate-200 bg-slate-100 shadow-xl"
  aria-label="Chat with Librarian"
>
  <div class="flex h-full flex-col">
    <header class="flex items-center justify-between border-b border-slate-200 bg-white px-4 py-3">
      <div>
        <h2 class="text-base font-semibold text-slate-800">Chat with Librarian</h2>
        <p class="text-xs text-slate-500">Answers use the current catalog.</p>
      </div>
      <button
        type="button"
        class="rounded-md border border-slate-200 px-2 py-1 text-sm font-semibold text-slate-600 hover:border-green-800 hover:text-green-800"
        data-action="librarian-chat#close"
        aria-label="Close chat"
      >
        Close
      </button>
    </header>

    <%= render "chats/messages", messages: [] %>

    <form action="<%= chat_path %>" method="post" data-librarian-chat-target="form" data-action="submit->librarian-chat#submit" class="border-t border-slate-200 bg-white p-4">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <input type="hidden" name="history" value="[]" data-librarian-chat-target="history">
      <label for="librarian-chat-message" class="block text-sm font-medium text-slate-700">Message</label>
      <textarea
        id="librarian-chat-message"
        name="message"
        rows="3"
        data-librarian-chat-target="message"
        class="mt-1 w-full resize-none rounded-md border border-slate-300 text-sm text-slate-800 focus:border-green-800 focus:ring-green-800"
      ></textarea>
      <p data-librarian-chat-target="error" class="mt-2 hidden text-sm text-red-700"></p>
      <div class="mt-3 flex items-center justify-between gap-3">
        <button
          type="button"
          data-action="librarian-chat#clear"
          class="rounded-md border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-600 hover:border-green-800 hover:text-green-800"
        >
          Clear
        </button>
        <button
          type="submit"
          data-librarian-chat-target="submit"
          class="rounded-md bg-green-800 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Send
        </button>
      </div>
    </form>
  </div>
</aside>
