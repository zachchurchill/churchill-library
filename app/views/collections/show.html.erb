<% provide(:title, @collection.title.titleize) %>
<div class="mx-auto">
  <div class="mb-4 flex flex-row justify-between gap-3">
    <%= link_to "Back", collections_path, class: "inline-flex min-h-10 items-center justify-center rounded-md bg-gray-300 px-4 py-2 text-sm font-semibold text-gray-800 shadow-sm hover:bg-gray-400" %>
    <% if logged_in? %>
      <%= link_to "Edit", edit_collection_path(@collection), class: "inline-flex min-h-10 items-center justify-center rounded-md bg-green-800 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-700" %>
    <% end %>
  </div>

  <section id="top-matter">
    <p class="text-sm font-medium leading-6 text-slate-600"><%= @collection.owner.name %></p>
    <h1 class="font-semibold text-2xl leading-tight tracking-tight text-slate-800"><%= @collection.title.titleize %></h1>
    <% if @collection.description.present? %>
      <p class="mt-1 leading-snug text-slate-800"><%= @collection.description %></p>
    <% end %>
    <p class="mt-2 text-sm font-medium text-slate-700"><%= collection_summary(@collection) %></p>
  </section>

  <section id="collection-books" class="mt-4">
    <ul class="divide-y divide-slate-300 border-y border-slate-300">
      <% @books.each do |book| %>
        <li aria-label="collection book" class="py-3">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div class="min-w-0">
              <p class="text-base font-semibold leading-snug text-slate-900"><%= book.title.titleize %></p>
              <p class="mt-1 text-sm leading-5 text-slate-600">by <%= book.author.name %></p>
            </div>
            <div class="flex flex-wrap gap-1.5 sm:max-w-xs sm:justify-end">
              <% book.genres.each do |genre| %>
                <span class="inline-flex items-center rounded-full bg-slate-200 px-2 py-0.5 text-xs font-medium leading-5 text-slate-700"><%= genre.name %></span>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
</div>
