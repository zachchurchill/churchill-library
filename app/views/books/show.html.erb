<% provide(:title, "Books") %>
<% if logged_in? %>
<div data-controller="librarian-chat">
<% end %>
<div class="mx-auto">
  <section id="top-matter">
    <h1 class="font-semibold text-2xl leading-tight tracking-tight text-slate-800">Welcome to the Library</h1>
    <p class="leading-snug text-slate-800">The Churchill Library houses books from all our family members. Explore our books using the provided search and filters.</p>
  </section>
  <section id="search-and-filters" class="mt-4 flex flex-col md:flex-row justify-between gap-4">
    <%= form_with(url: books_path, method: :get, class: "basis-3/4 flex flex-col justify-between gap-2", data: { controller: "books-filter", action: "submit->books-filter#submit" }) do |f| %>
      <div class="relative">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" class="inline absolute mt-4 ml-3">
          <path d="M13 13L10.1 10.1M11.6667 6.33333C11.6667 9.27885 9.27885 11.6667 6.33333 11.6667C3.38781 11.6667 1 9.27885 1 6.33333C1 3.38781 3.38781 1 6.33333 1C9.27885 1 11.6667 3.38781 11.6667 6.33333Z" stroke="#1E1E1E" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <%= f.search_field :title, placeholder: "Search by title...", value: @filters["title"], class: "w-full pl-8 rounded-full border border-solid border-slate-200 focus:border-transparent focus:shadow-none", data: { action: "input->books-filter#search" } %>
      </div>
      <div class="flex md:flex-row flex-col">
        <div class="w-full mr-0 md:mr-3">
          <%= f.label :owner, class: "block text-xs md:text-sm font-medium leading-6 text-gray-900" %>
          <%= select_tag :owner, render("filter_options", records: @owners, selected_id: @owner&.id, blank_label: "All Owners"), class: "w-full rounded-lg border border-solid border-slate-200", data: { action: "change->books-filter#submit" } %>
        </div>
        <div class="w-full mx-0 md:mx-2">
          <%= f.label :author, class: "block text-xs md:text-sm font-medium leading-6 text-gray-900" %>
          <%= select_tag :author, render("filter_options", records: @authors, selected_id: @author&.id, blank_label: "All Authors"), class: "w-full rounded-lg border border-solid border-slate-200", data: { action: "change->books-filter#submit" } %>
        </div>
        <div class="w-full ml-0 md:ml-3">
          <%= f.label :genre, class: "block text-xs md:text-sm font-medium leading-6 text-gray-900" %>
          <%= select_tag :genre, render("filter_options", records: @genres, selected_id: @genre&.id, blank_label: "All Genres"), class: "w-full rounded-lg border border-solid border-slate-200", data: { action: "change->books-filter#submit" } %>
        </div>
      </div>
    <% end %>
    <div class="basis-1/4 min-h-12 md:max-w-64 flex flex-row md:flex-col justify-end gap-2">
      <% if logged_in? %>
      <button id="ai-chat" type="button" class="basis-full py-2 md:py-0 border border-solid rounded-md text-xs md:text-sm font-semibold text-slate-600 shadow-sm border-green-600 hover:border-green-800 cursor-pointer" data-action="librarian-chat#open">Chat with Librarian</button>
      <%= link_to "Add Book", book_path, class: "basis-full p0 rounded-md text-xs md:text-sm font-semibold text-white shadow-sm bg-green-800 hover:bg-green-700 cursor-pointer content-center text-center" %>
      <% end %>
    </div>
  </section>
  <section id="books-table" class="mt-4">
    <table class="w-full table-auto md:table-fixed">
      <thead>
        <tr class="border-b border-solid border-slate-200 text-base md:text-lg text-left text-slate-800">
          <th class="w-2/12 font-medium text-inherit">Owner</th>
          <th class="w-4/12 font-medium text-inherit">Title</th>
          <th class="w-3/12 font-medium text-inherit">Author</th>
          <th class="w-3/12 font-medium text-inherit">Genres</th>
        </tr>
      </thead>
      <tbody id="books-table-body" class="font-light text-sm md:text-base text-slate-800 space-y-8 md:space-y-6 lg:space-y-4">
        <%= render "books_table_rows", books: @books %>
      </tbody>
    </table>
    <%= render "pagination", books: @books, filters: @canonical_query %>
  </section>
</div>
<% if logged_in? %>
  <%= render "chats/panel" %>
</div>
<% end %>
